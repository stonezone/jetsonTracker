# JetsonTracker .gitignore
# Comprehensive ignore file for multi-platform robotics project

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# =============================================================================
# Xcode / Swift / iOS
# =============================================================================
xcuserdata/
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
timeline.xctimeline
playground.xcworkspace
.swiftpm/
.build/
DerivedData/
Carthage/Build/
Dependencies/
.accio/
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output
iOSInjectionProject/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/
*.egg-info/
*.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
*.coverage
.coverage
.coverage.*
htmlcov/

# =============================================================================
# Archived STM32 / Embedded Build Artifacts
# =============================================================================
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/firmware/*/Debug/
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/firmware/*/Release/
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/firmware/*/.settings/
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/firmware/*/.metadata/
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/stepper_control/
*.o
*.elf
*.map
*.bin
*.hex

# =============================================================================
# ML Models (too large for git - download separately)
# =============================================================================
*.pt
*.onnx
*.engine
*.weights
models/

# =============================================================================
# IDEs / Editors
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
jetson/*.log

# =============================================================================
# Secrets (NEVER commit)
# =============================================================================
*.json.credentials
credentials*.json
*.pem
*.key
secrets/
*.local.json
*.local.yaml
.env
.env.*
!.env.example

# =============================================================================
# Temporary / Cache
# =============================================================================
*.tmp
*.temp
.cache/
jetson/fixes.jsonl

# =============================================================================
# AI Assistant / Tool Directories
# =============================================================================
.cursor/
.serena/
.gemini-clipboard/

# =============================================================================
# Claude Code / Claude OS
# =============================================================================
# .claude/ contains symlinks to local claude-os installation - don't track
.claude/

# .claude-os/ - track config, exclude state/cache
.claude-os/claude-os-state.json
.claude-os/.index_state
.claude-os/.commit_count
.claude-os/*.db
.claude-os/tree_sitter_cache.db

# agent-os/ - track config/specs, exclude state files
agent-os/.agent-os-state.json
agent-os/**/*.tmp
agent-os/**/*.log

# =============================================================================
# Archive and Backup (local only, not for repo)
# =============================================================================
archive/
archive*/
Archive*/
*_archive/
backup*/
Backup*/
*.backup
*.bak

# =============================================================================
# Markdown Files - Selective Tracking
# =============================================================================
# Ignore random notes/drafts by default
*.md

# Root level docs - KEEP
!README.md
!CLAUDE.md
!BOM.md
!CONTRIBUTING.md
!CHANGELOG.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!LICENSE.md

# docs/ folder - KEEP ALL
!docs/
!docs/**
!docs/**/*.md
# the docs negations above re-include everything under docs/ — re-ban OS litter
**/.DS_Store

# Component READMEs - KEEP
!orin/README.md
!orin/*/README.md
!archive/
!archive/legacy-20260606/
!archive/legacy-20260606/**/
!archive/legacy-20260606/**/README.md

# GitHub templates - KEEP
!.github/
!.github/**/*.md

docs/.DS_Store
docs/wiring/.DS_Store
docs/superpowers/.DS_Store

# Agent collaboration state
.agent-collab/
.codex/

# Archived Nucleo local/reference artifacts - keep GitHub limited to current archived F401 build files.
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/.DS_Store
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/**/.DS_Store
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/_archive/
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/docs/MORPHO_PINOUT_REFERENCE.md
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/docs/um1724-stm32-nucleo64-boards-mb1136-stmicroelectronics.pdf
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/firmware/stepper_control/STM32F446RETX_FLASH.ld
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/firmware/stepper_control/Startup/startup_stm32f446retx.s
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/images/ STM32 Nucleo-F401RE-pinout-diagram.jpg
archive/legacy-20260606/stm32-nucleo-stepper/nucleo/images/ STM32 Nucleo-F401RE-pinout.jpg

# =============================================================================
# End of .gitignore
# =============================================================================

# Deploy-time artifact (deploy.sh stamps + cleans it; never commit)
orin/wavecam/version.json

# xcodegen-generated watch plist (source of truth: ios/WaveCam/project.yml info block)
ios/WaveCam/InfoWatch.plist
