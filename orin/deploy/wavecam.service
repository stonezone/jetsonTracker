# WaveCam vision servo runner. The service starts paused so watchdog restarts
# restore video/API without immediately handing PTZ to the autonomous loop.

[Unit]
Description=WaveCam vision servo runner
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=4

[Service]
Type=simple
User=zack
Group=zack
WorkingDirectory=/data/projects/gimbal/wavecam
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/data/projects/gimbal/wavecam
Environment=WAVECAM_START_PAUSED=1
ExecStart=/usr/bin/python3 /data/projects/gimbal/wavecam/run.py /data/projects/gimbal/wavecam/config.orin.servo.yaml
Restart=always
RestartSec=2
KillSignal=SIGINT
# TensorRT teardown can report SIGABRT after the Python finally block runs.
# Treat that shutdown signal as clean so deliberate systemctl stop is not red.
SuccessExitStatus=SIGINT SIGTERM SIGABRT
TimeoutStopSec=10
ExecStopPost=/usr/bin/python3 /data/projects/gimbal/wavecam/tools/ptz_stop_once.py 192.168.100.88 1259
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
